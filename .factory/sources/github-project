#!/usr/bin/env bash
set -euo pipefail

project_owner=""
project_number=""
status_field=""
state=""
labels=()
has_labels=0

while (($# > 0)); do
  case "$1" in
    --project-owner|--project-number|--status-field|--state|--label)
      [[ $# -ge 2 ]] || { echo "missing value for $1" >&2; exit 2; }
      option="$1"
      value="$2"
      case "$option" in
        --project-owner) project_owner="$value" ;;
        --project-number) project_number="$value" ;;
        --status-field) status_field="$value" ;;
        --state) state="$value" ;;
        --label) labels+=("$value"); has_labels=1 ;;
      esac
      shift 2
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

[[ -n "$project_owner" ]] || { echo "--project-owner is required" >&2; exit 2; }
[[ "$project_number" =~ ^[1-9][0-9]*$ ]] || { echo "--project-number must be positive" >&2; exit 2; }
[[ -n "$status_field" ]] || { echo "--status-field is required" >&2; exit 2; }
[[ -n "$state" ]] || { echo "--state is required" >&2; exit 2; }

repository=$(gh repo view --json nameWithOwner --jq '.nameWithOwner')
project_id=$(gh project view "$project_number" \
  --owner "$project_owner" \
  --format json \
  --jq '.id')
field_summary=$(FACTORY_STATUS_FIELD="$status_field" \
  FACTORY_SOURCE_STATE="$state" \
  gh project field-list "$project_number" \
    --owner "$project_owner" \
    --limit 1000 \
    --format json \
    --jq '
      [.fields[] | select(.name == env.FACTORY_STATUS_FIELD)] as $fields
      | [
          ($fields | length),
          ($fields[0].type // ""),
          ([$fields[0].options[]? | select(.name == env.FACTORY_SOURCE_STATE)] | length)
        ]
      | @tsv
    ')
IFS=$'\t' read -r field_count field_type option_count <<<"$field_summary"
if [[ "$field_count" != "1" ]]; then
  echo "Project field '$status_field' must exist exactly once" >&2
  exit 1
fi
if [[ "$field_type" != "ProjectV2SingleSelectField" ]]; then
  echo "Project field '$status_field' must be a single-select field" >&2
  exit 1
fi
if [[ "$option_count" != "1" ]]; then
  echo "Project field '$status_field' must contain status '$state' exactly once" >&2
  exit 1
fi

max_results=1000
open_count=$(gh issue list \
  --state open \
  --limit "$((max_results + 1))" \
  --json number \
  --jq 'length')
if ((open_count > max_results)); then
  echo "GitHub issue result was truncated; narrow the repository backlog" >&2
  exit 1
fi

search_query="repo:${repository} is:issue is:open"
if ((has_labels)); then
  for label in "${labels[@]}"; do
    escaped=${label//\\/\\\\}
    escaped=${escaped//\"/\\\"}
    search_query+=" label:\"${escaped}\""
  done
fi

graphql='query($searchQuery:String!,$endCursor:String,$statusField:String!){search(type:ISSUE,query:$searchQuery,first:100,after:$endCursor){pageInfo{hasNextPage endCursor} nodes{... on Issue{number title body url labels(first:100){nodes{name}} projectItems(first:100){nodes{project{id} fieldValueByName(name:$statusField){... on ProjectV2ItemFieldSingleSelectValue{name}}}}}}}}'
results=$(mktemp -t factory-github-project-source.XXXXXX)
trap 'rm -f "$results"' EXIT

if ! FACTORY_SOURCE_PROJECT_ID="$project_id" \
  FACTORY_SOURCE_STATE="$state" \
  gh api graphql --paginate \
    -f query="$graphql" \
    -F searchQuery="$search_query" \
    -F statusField="$status_field" \
    --jq '
      .data.search.nodes[]
      | select(any(.projectItems.nodes[]?;
          .project.id == env.FACTORY_SOURCE_PROJECT_ID
          and .fieldValueByName.name == env.FACTORY_SOURCE_STATE))
      | {
          key: ("#" + (.number | tostring)),
          title: .title,
          description: (.body // "")[0:2000],
          state: env.FACTORY_SOURCE_STATE,
          labels: [.labels.nodes[].name],
          url: .url
        }
    ' >"$results"
then
  exit 1
fi

printf '{"issues":['
separator=""
while IFS= read -r issue; do
  [[ -n "$issue" ]] || continue
  printf '%s%s' "$separator" "$issue"
  separator=","
done <"$results"
printf ']}\n'
